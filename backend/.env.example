# Environment Variables Template
# Copy file ini ke .env.development atau .env.production dan sesuaikan nilainya

# Database Configuration
DB_HOST=localhost
DB_NAME=sibt
DB_USER=root
DB_PASS=
DB_PORT=3306
DB_POOL_MAX=2
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Server Configuration
PORT=4000
NODE_ENV=development

# JWT Secret (gunakan string random yang panjang di production!)
JWT_SECRET=supersecretkey

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:5173

# Admin Secret Code (untuk registrasi admin pertama)
ADMIN_SECRET_CODE=ADMIN
